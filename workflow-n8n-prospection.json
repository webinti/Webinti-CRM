            },
            {
              "name": "hasWebsite",
              "value": "={{ $json.hasWebsite }}"
            },
            {
              "name": "websiteScore",
              "value": "={{ $json.websiteScore }}"
            },
            {
              "name": "websiteIssues",
              "value": "={{ JSON.stringify($json.websiteIssues) }}"
            },
            {
              "name": "source",
              "value": "api_gouv"
            },
            {
              "name": "status",
              "value": "new"
            },
            {
              "name": "priority",
              "value": "={{ $json.websiteScore < 30 ? 80 : $json.websiteScore < 60 ? 60 : 40 }}"
            }
          ]
        },
        "options": {}
      },
      "id": "create-lead",
      "name": "Créer Lead CRM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
