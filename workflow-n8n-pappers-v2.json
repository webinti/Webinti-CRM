        [{"node": "Pas de site", "type": "main", "index": 0}]
      ]
    },
    "Wait 2s": {
      "main": [[{"node": "Lighthouse", "type": "main", "index": 0}]]
    },
    "Lighthouse": {
      "main": [[{"node": "Analyse scores", "type": "main", "index": 0}]]
    },
    "Analyse scores": {
      "main": [[{"node": "Créer Lead CRM", "type": "main", "index": 0}]]
    },
    "Pas de site": {
      "main": [[{"node": "Créer Lead CRM", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": []
